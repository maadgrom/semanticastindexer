{
  "mcpServers": {
    "semantic-code-search": {
      "command": "/absolute/path/to/semanticastindexer",
      "args": [
        "mcp",
        "--backend", "duckdb",
        "--embedder", "ollama",
        "--collection", "source_code"
      ],
      "cwd": "/path/to/the/project/you/want/to/search"
    }
  }
}
